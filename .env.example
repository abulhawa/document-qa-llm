# Mode & logging
NAMESPACE=dev
TEST_MODE=off
LOG_LEVEL=INFO

# URLs
OPENSEARCH_URL=http://localhost:9200
QDRANT_URL=http://localhost:6333
EMBEDDING_API_URL=http://localhost:8000/embed

# LLM provider (default: local text-generation-webui)
USE_GROQ=false
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai
GROQ_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=http://localhost:5000

# Bases (namespaced at runtime)
CHUNKS_INDEX_BASE=documents
INGEST_LOG_INDEX_BASE=ingest_logs
QDRANT_COLLECTION_BASE=document_chunks

# Toggles
USE_STUB_EMBEDDER=false
USE_STUB_LLM=false
QA_GROUNDING_ENABLED=false
QA_GROUNDING_THRESHOLD=0.30

# Sizes
EMBEDDING_SIZE=768
CHUNK_SIZE=800
CHUNK_OVERLAP=100
